### Localhost example
# For stable-localhost / SQLite-based local development, keep your local .env.local separate.

### Vercel required
DATABASE_URL=
NEXTAUTH_URL=
NEXTAUTH_SECRET=
IMAGE_BACKEND_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_CREDITS_100_PRICE_ID=
STRIPE_CREDITS_500_PRICE_ID=
STRIPE_CREDITS_1000_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
ADMIN_EMAILS=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

### Vercel optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_APP_LOGO=
NEXT_PUBLIC_APP_LOGO_ALT=
NEXT_PUBLIC_HERO_IMAGE=
NEXT_PUBLIC_HERO_IMAGE_ALT=
PRICE_COMPARISON_API_URL=

### Railway required
# No required custom variables to boot.

### Railway recommended
ENABLE_BIREFNET=false
